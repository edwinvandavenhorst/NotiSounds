<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        App Sandbox — required for Mac App Store distribution.
        The local build.sh uses ad-hoc signing which does not enforce
        entitlements, so this does not affect local development.
    -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!--
        AppleScript automation — allows NSAppleScript to send Apple Events
        to System Events, which is the only public API path to read and set
        the macOS alert volume.  Paired with NSAppleEventsUsageDescription
        in Info.plist.
    -->
    <key>com.apple.security.automation.apple-events</key>
    <dict>
        <key>com.apple.systemevents</key>
        <true/>
    </dict>
</dict>
</plist>
